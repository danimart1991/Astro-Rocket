---
/**
 * ContactView — the Contact page body.
 *
 * Shared by the default-locale route (`/contact`) and the locale-prefixed route
 * (`/<locale>/contact`). Page copy is read from `pages.contact.*`; the embedded
 * `ContactForm` localizes itself from the URL path, so the form fields follow
 * the active locale automatically. Untranslated keys fall back to the default
 * locale.
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Alert from '@/components/ui/feedback/Alert/Alert.astro';
import { Hero } from '@/components/hero';
import ContactForm from '@/components/patterns/ContactForm.astro';
import siteConfig from '@/config/site.config';
import { resolveSocialLinks } from '@/lib/utils';
import { t, tData, defaultLocale, localizedPath } from '@/i18n';

interface Props {
  /** Locale whose copy this page renders. Defaults to the site default. */
  locale?: string;
}

const { locale = defaultLocale } = Astro.props;

const hero = tData<{
  badge: string;
  titleLead: string;
  titleHighlight: string;
  description: string;
}>('pages.contact.hero', locale)!;

const socialLinks = resolveSocialLinks(siteConfig.socialLinks);
const collaborationsUrl = localizedPath('/collaborations', locale);

const channels = [
  {
    icon: 'mail',
    label: t('pages.contact.emailLabel', locale),
    value: siteConfig.email,
    note: t('pages.contact.emailNote', locale),
    href: `mailto:${siteConfig.email}`,
    external: false,
  },
  ...socialLinks.map((link) => ({
    icon: link.icon,
    label: link.label,
    value: link.href.replace(/^https?:\/\/(www\.)?/, ''),
    note: t('pages.contact.socialNote', locale),
    href: link.href,
    external: true,
  })),
];
---

<PageLayout
  title={t('pages.contact.meta.title', locale)}
  description={t('pages.contact.meta.description', locale)}
  eagerReveal
>
  <Hero layout="centered" size="sm" class="isolate" showHeroHalo>
    <Badge slot="badge" variant="brand" pill>
      <Icon name="mail" size="sm" />
      {hero.badge}
    </Badge>

    <h1 slot="title">
      {hero.titleLead}
      <span class="text-brand-500">{hero.titleHighlight}</span>
    </h1>

    <p slot="description" class="!text-balance">
      {hero.description}
    </p>
  </Hero>

  <!-- Contact Section -->
  <section
    class="bg-background-secondary border-border relative isolate overflow-hidden border-t py-[var(--space-section-md)]"
  >
    <div class="relative z-10 mx-auto max-w-5xl px-6">
      <div class="glitch:grid-cols-5 glitch:gap-16 grid grid-cols-1 items-stretch gap-10">
        <!-- Left column: contact form -->
        <div
          class="glitch:col-span-3 glitch:max-w-none glitch:mx-0 h-full sm:mx-auto sm:max-w-xl"
          data-reveal
          data-reveal-ease="smooth"
        >
          <Card padding="lg" class="flex h-full flex-col justify-center">
            <h2
              class="font-display text-foreground glitch:text-left mb-6 text-xl font-bold sm:text-center"
            >
              {t('pages.contact.formTitle', locale)}
            </h2>
            <Alert variant="info" class="mb-6">
              <span>{t('pages.contact.collaborationNotice.intro', locale)}</span>
              <a
                href={collaborationsUrl}
                class="text-foreground decoration-brand-500/50 hover:text-brand-500 hover:decoration-brand-500 font-medium underline underline-offset-4 transition"
                >{t('pages.contact.collaborationNotice.linkLabel', locale)}</a
              ><span>{t('pages.contact.collaborationNotice.outro', locale)}</span>
            </Alert>
            <ContactForm />
          </Card>
        </div>

        <!-- Right column: contact channels -->
        <div
          class="glitch:col-span-2 glitch:max-w-none glitch:mx-0 space-y-4 sm:mx-auto sm:max-w-xl"
          data-reveal
          data-reveal-delay="1"
          data-reveal-ease="smooth"
        >
          <div class="glitch:text-left sm:text-center">
            <h2 class="font-display text-foreground mb-1 text-lg font-bold">
              {t('pages.contact.channelsTitle', locale)}
            </h2>
            <p class="text-foreground-muted text-sm">
              {t('pages.contact.channelsSubtitle', locale)}
            </p>
          </div>

          <!-- Channel list -->
          <div class="space-y-2">
            {
              channels.map((ch) => (
                <a
                  href={ch.href}
                  {...(ch.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                  class="group block"
                  title={ch.note}
                >
                  <Card hover padding="sm" class="h-full">
                    <div class="flex items-center gap-3">
                      <div class="from-brand-500/20 to-brand-500/5 text-brand-500 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br">
                        <Icon name={ch.icon} size="sm" />
                      </div>
                      <div class="min-w-0 flex-1">
                        <p class="text-foreground text-sm font-semibold">{ch.label}</p>
                        <p class="text-foreground-muted truncate text-xs">{ch.value}</p>
                      </div>
                      <Icon
                        name="arrow-up-right"
                        size="sm"
                        class="text-foreground-muted group-hover:text-brand-500 shrink-0 transition-colors"
                      />
                    </div>
                  </Card>
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
